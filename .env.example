# Configuración del servidor
PORT=8080

# URL de conexión a MongoDB (ejemplo: mongodb+srv://usuario:password@cluster.mongodb.net/database)
MONGO_URL=mongodb+srv://tu_usuario:tu_password@cluster0.example.mongodb.net/nombre_db

# Secreto para la firma de JWT
JWT_SECRET=tu_secreto_super_seguro_aqui

# Nombre de la cookie donde se almacenará el token
COOKIE_NAME=nombre_de_tu_cookie
